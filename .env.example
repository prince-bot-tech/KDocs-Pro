# ---- Rename this file to .env before running locally ----
# ---- On Render, you paste these into the "Environment" tab instead ----

PORT=10000

# Daraja (M-Pesa) credentials - get these from https://developer.safaricom.co.ke
DARAJA_CONSUMER_KEY=your_consumer_key_here
DARAJA_CONSUMER_SECRET=your_consumer_secret_here
DARAJA_SHORTCODE=174379
DARAJA_PASSKEY=your_passkey_here
DARAJA_ENV=sandbox
# This must be your live Render URL + /api/daraja/callback once deployed
DARAJA_CALLBACK_URL=https://your-app-name.onrender.com/api/daraja/callback

# Price per download, in Kenyan Shillings
PRICE_KES=25
